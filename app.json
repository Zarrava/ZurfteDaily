{
  "expo": {
    "name": "Zurfte Daily",
    "slug": "ZurfteDaily",
    "version": "1.0.0",
    "description": "Daily motivational quotes for entrepreneurs and growth-minded people.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zurftedaily",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#0B1F33",
    "backgroundColor": "#0B1F33",
    "ios": {
      "bundleIdentifier": "com.zurfte.daily",
      "buildNumber": "1",
      "supportsTablet": true,
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "com.zurfte.daily",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0B1F33",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [],
      "blockedPermissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B1F33",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      "expo-status-bar"
    ],
    "extra": {
      "privacyPolicyNote": "See docs/PRIVACY_POLICY.md — host publicly before Play upload.",
      "eas": {
        "projectId": "51f788a7-edc6-4e8c-8299-c8ec3a00c5ac"
      }
    },
    "owner": "zurfte"
  }
}
